<div id="pivot-cart-shipping-bar"></div>

<script>
(function() {
  var FREE_SHIPPING_THRESHOLD = 7500;

  function formatMoney(cents) {
    return "$" + (cents / 100).toFixed(2);
  }

  function buildBarHTML(cart) {
    if (cart.item_count === 0) return '';

    var total = cart.total_price;
    if (total >= FREE_SHIPPING_THRESHOLD) {
      return '<div style="background:rgba(62,214,96,0.15);border-radius:8px;padding:12px 16px;margin-bottom:16px;">' +
        '<p style="font-size:14px;margin:0;color:#1a6b2e;font-weight:500;">🎉 You have unlocked free shipping!</p>' +
        '</div>';
    } else {
      var remaining = FREE_SHIPPING_THRESHOLD - total;
      var pct = Math.min(100, Math.round((total / FREE_SHIPPING_THRESHOLD) * 100));
      return '<div style="background:#f4f4f2;border-radius:8px;padding:12px 16px;margin-bottom:16px;">' +
        '<p style="font-size:14px;margin:0 0 8px;color:#000;">Add <strong>' + formatMoney(remaining) + '</strong> more for free shipping!</p>' +
        '<div style="background:#ddd;border-radius:99px;height:12px;width:100%;overflow:hidden;display:block;">' +
        '<div style="background:#3ED660;height:12px;width:' + pct + '%;border-radius:99px;transition:width 0.4s ease;display:block;"></div>' +
        '</div></div>';
    }
  }

  function updateBar() {
    fetch('/cart.js')
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        var el = document.getElementById('pivot-cart-shipping-bar');
        if (el) el.innerHTML = buildBarHTML(cart);
      });
  }

  document.addEventListener('DOMContentLoaded', updateBar);

  document.addEventListener('change', function(e) {
    if (e.target && (e.target.name === 'updates[]' || e.target.closest('[data-cart-item-quantity]'))) {
      setTimeout(updateBar, 500);
    }
  });

  setInterval(updateBar, 2000);
})();
</script>

{% schema %}
{
  "name": "Cart Shipping Bar",
  "settings": [],
  "presets": [{"name": "Cart Shipping Bar"}]
}
{% endschema %}
