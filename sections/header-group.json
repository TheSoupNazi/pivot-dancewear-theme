        "custom_liquid": "<div id=\"pivot-announcement-bar\" style=\"background:#000;color:#fff;text-align:center;padding:10px 16px;font-size:14px;font-family:inherit;min-height:18px;\">\n  <span id=\"pivot-announcement-text\">Welcome to our store! We are so glad you are here!</span>\n</div>\n<script>\n(function() {\n  var FREE_SHIPPING_THRESHOLD = 7500;\n  var isHomepage = {% if request.page_type == \"index\" %}true{% else %}false{% endif %};\n  var WELCOME_MESSAGE = \"Welcome to our store! We are so glad you are here!\";\n  var STATIC_SHIPPING_MESSAGE = \"Free shipping on orders $75+\";\n  var rotateTimer = null;\n  function formatMoney(cents) {\n    return \"$\" + (cents / 100).toFixed(2);\n  }\n  function getShippingMessage(callback) {\n    fetch(\"/cart.js\")\n      .then(function(res) { return res.json(); })\n      .then(function(cart) {\n        var total = cart.total_price;\n        if (total >= FREE_SHIPPING_THRESHOLD) {\n          callback(\"You have got free shipping!\");\n        } else {\n          var remaining = FREE_SHIPPING_THRESHOLD - total;\n          callback(\"Add \" + formatMoney(remaining) + \" more for free shipping!\");\n        }\n      })\n      .catch(function() {\n        callback(STATIC_SHIPPING_MESSAGE);\n      });\n  }\n  function setBarText(text) {\n    var bar = document.getElementById(\"pivot-announcement-text\");\n    if (bar) bar.textContent = text;\n  }\n  function startRotation(shippingMsg) {\n    var messages = [WELCOME_MESSAGE, shippingMsg];\n    var index = 0;\n    setBarText(messages[0]);\n    if (rotateTimer) clearInterval(rotateTimer);\n    rotateTimer = setInterval(function() {\n      index = (index + 1) % messages.length;\n      setBarText(messages[index]);\n    }, 4000);\n  }\n  function init() {\n    if (isHomepage) {\n      startRotation(STATIC_SHIPPING_MESSAGE);\n    } else {\n      getShippingMessage(function(shippingMsg) {\n        startRotation(shippingMsg);\n      });\n    }\n  }\n  init();\n  var lastCartCount = null;\n  setInterval(function() {\n    fetch(\"/cart.js\")\n      .then(function(res) { return res.json(); })\n      .then(function(cart) {\n        if (cart.item_count !== lastCartCount) {\n          lastCartCount = cart.item_count;\n          init();\n        }\n      });\n  }, 2000);\n})();\n</script>",
