        "custom_liquid": "<script>\n(function() {\n  var FREE_SHIPPING_THRESHOLD = 7500;\n\n  function formatMoney(cents) {\n    return \"$\" + (cents / 100).toFixed(2);\n  }\n\n  function buildBarHTML(cart) {\n    var total = cart.total_price;\n    if (total >= FREE_SHIPPING_THRESHOLD) {\n      return '<div id=\"pivot-notif-shipping\" style=\"background:rgba(62,214,96,0.15);border-radius:8px;padding:10px 14px;margin:0 0 12px;\">' +\n        '<p style=\"font-size:13px;margin:0;color:#27500a;\">You have unlocked free shipping!</p>' +\n        '</div>';\n    } else {\n      var remaining = FREE_SHIPPING_THRESHOLD - total;\n      var pct = Math.min(100, Math.round((total / FREE_SHIPPING_THRESHOLD) * 100));\n      return '<div id=\"pivot-notif-shipping\" style=\"background:#f4f4f2;border-radius:8px;padding:10px 14px;margin:0 0 12px;\">' +\n        '<p style=\"font-size:13px;margin:0 0 6px;color:#000;\">Add ' + formatMoney(remaining) + ' more for free shipping!</p>' +\n        '<div style=\"background:#ddd;border-radius:99px;height:12px;width:100%;overflow:hidden;display:block;\">' +\n        '<div style=\"background:#3ED660;height:12px;width:' + pct + '%;border-radius:99px;transition:width 0.4s ease;display:block;\"></div>' +\n        '</div></div>';\n    }\n  }\n\n  function injectBar(cart) {\n    var existing = document.getElementById('pivot-notif-shipping');\n    var html = buildBarHTML(cart);\n    var temp = document.createElement('div');\n    temp.innerHTML = html;\n    var newEl = temp.firstElementChild;\n\n    if (existing) {\n      existing.parentNode.replaceChild(newEl, existing);\n    } else {\n      var notif = document.getElementById('cart-notification');\n      if (!notif) return;\n      var buttons = notif.querySelector('.cart-notification__links');\n      if (buttons) {\n        notif.insertBefore(newEl, buttons);\n      }\n    }\n  }\n\n  var observer = new MutationObserver(function() {\n    var notif = document.getElementById('cart-notification');\n    if (notif && notif.classList.contains('active')) {\n      fetch('/cart.js')\n        .then(function(r) { return r.json(); })\n        .then(function(cart) { injectBar(cart); });\n    }\n  });\n\n  document.addEventListener('DOMContentLoaded', function() {\n    var target = document.getElementById('cart-notification');\n    if (target) {\n      observer.observe(target, { attributes: true, attributeFilter: ['class'] });\n    }\n  });\n})();\n</script>",
